# Minecraft Sunucu Yapılandırması
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin

# Minecraft Sunucu Bilgileri
SERVER_HOST=localhost
SERVER_PORT=25575
RCON_PASSWORD=your_secure_password_here

# API Yapılandırması
API_PORT=8000

# Güvenlik Ayarları (Opsiyonel)
# API key ayarlandığında, tüm API isteklerinde X-API-Key header'ı gerekli
API_KEY=

# IP Whitelist - Sadece belirtilen IP'lerden erişime izin verir (virgülle ayrılmış)
# Boş bırakılırsa tüm IP'lerden erişime izin verilir
ALLOWED_IPS=

# CORS Ayarları
# Cross-Origin Resource Sharing - Farklı domain'lerden erişim için
ENABLE_CORS=true
# İzin verilen origin'ler (virgülle ayrılmış, * = tüm origin'ler)
CORS_ORIGINS=*

# Loglama Seviyesi
# Seçenekler: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Notlar:
# - RCON_PASSWORD değeri, Minecraft sunucunuzun server.properties dosyasındaki
#   rcon.password değeri ile aynı olmalıdır
# - API_KEY boş bırakılırsa API key kontrolü yapılmaz
# - ALLOWED_IPS boş bırakılırsa tüm IP'lerden erişime izin verilir
# - ENABLE_CORS=false yapılırsa CORS devre dışı kalır

